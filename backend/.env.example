# Environment
NODE_ENV=development
PORT=3001

# Frontend
FRONTEND_URL=http://localhost:3000

# JWT Authentication (REQUIRED)
JWT_SECRET=generate-a-strong-random-secret-here
JWT_EXPIRES_IN=7d

# Soroban/Stellar Configuration
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
SOROBAN_CONTRACT_ID=your_contract_id_here
SOROBAN_NETWORK=testnet
SOROBAN_SIMULATION_ACCOUNT=simulation_account

# Webhook Configuration
# Comma-separated list of webhook URLs
WEBHOOK_URLS=https://example.com/webhook1,https://example.com/webhook2

# Comma-separated list of webhook secrets (must match order of URLs)
WEBHOOK_SECRETS=secret1,secret2

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/ajo

# Email Service (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key_here
EMAIL_FROM=noreply@ajo.app

# Redis (required for background job queues and email queue)
REDIS_URL=redis://localhost:6379

# Rate Limiting (15 mins = 900000 ms)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Strict Rate Limiting (auth, webhooks, jobs)
STRICT_LIMIT_WINDOW_MS=3600000
STRICT_LIMIT_MAX_REQUESTS=10

# Groups write limiter
GROUPS_WRITE_WINDOW_MS=900000
GROUPS_WRITE_MAX_REQUESTS=30

# Analytics limiter
ANALYTICS_LIMIT_WINDOW_MS=900000
ANALYTICS_LIMIT_MAX_REQUESTS=60

# Public read limiter
PUBLIC_READ_WINDOW_MS=900000
PUBLIC_READ_MAX_REQUESTS=200

# DDoS Protection
DDOS_ATTACK_THRESHOLD=200
DDOS_ATTACK_WINDOW_MS=60000
DDOS_BLOCK_DURATION_MS=3600000

# Request Throttling (per-IP per-second)
THROTTLE_WINDOW_MS=1000
THROTTLE_MAX_RPS=10
THROTTLE_DELAY_MS=500

# IP Blocklist (comma-separated IPs to permanently block)
BLOCKED_IPS=
